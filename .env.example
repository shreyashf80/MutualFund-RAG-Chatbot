# =============================================================
# Mutual Fund FAQ Assistant — Environment Configuration
# =============================================================
# Copy this file to `.env` and fill in the values before running.
#   cp .env.example .env
# =============================================================

# ---- Groq LLM ----
GROQ_API_KEY=your_groq_api_key_here

# ---- Embedding Model ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- LLM Configuration ----
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=200

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=mutual_fund_faq

# ---- Retrieval ----
TOP_K_RESULTS=3
SIMILARITY_THRESHOLD=0.3

# ---- Chunking ----
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ---- Scheduler ----
SCHEDULER_HOUR=10
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Kolkata

# ---- Server ----
HOST=0.0.0.0
PORT=8000
